#!/bin/sh
# This file is used by Xcode to locate Flutter SDK
# Xcode Cloud will use this to find Flutter during the build

# Try to find Flutter in PATH first
if command -v flutter >/dev/null 2>&1; then
  export FLUTTER_ROOT=$(dirname $(dirname $(which flutter)))
  echo "Found Flutter at: $FLUTTER_ROOT"
else
  # If Flutter is not in PATH, try common locations
  if [ -d "/usr/local/flutter" ]; then
    export FLUTTER_ROOT="/usr/local/flutter"
    export PATH="$FLUTTER_ROOT/bin:$PATH"
  elif [ -d "$HOME/flutter" ]; then
    export FLUTTER_ROOT="$HOME/flutter"
    export PATH="$FLUTTER_ROOT/bin:$PATH"
  else
    echo "Warning: Flutter not found. The ci_pre_xcodebuild.sh script should install it."
  fi
fi
